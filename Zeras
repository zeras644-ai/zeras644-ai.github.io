<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ONE DAY OF FIGHTER</title>

<link href="https://fonts.googleapis.com/css2?family=Oswald:wght@300;400;600;700&family=Roboto+Condensed:wght@300;400;700&display=swap" rel="stylesheet">

<style>
:root{
--orange:#ff5722;
--dark:#1a1a1a;
--darker:#0d0d0d;
}

*{margin:0;padding:0;box-sizing:border-box;}

html,body{
width:100%;
height:100%;
scroll-behavior:smooth;
}

body{
background:linear-gradient(45deg, #1a0f06 25%, transparent 25%, transparent 75%, #1a0f06 75%, #1a0f06),
            linear-gradient(45deg, #1a0f06 25%, transparent 25%, transparent 75%, #1a0f06 75%, #1a0f06);
background-size:40px 40px;
background-position:0 0, 20px 20px;
background-color:#2a1a0f;
color:#fff;
font-family:'Roboto Condensed',sans-serif;
}

/* ===== HEADER ===== */
header{
position:fixed;
top:0;
left:0;
width:100%;
display:flex;
justify-content:space-between;
align-items:center;
padding:12px 20px;
background:rgba(0,0,0,0.9);
z-index:1000;
border-bottom:1px solid rgba(255,255,255,0.1);
}

.logo-box{
display:flex;
align-items:center;
gap:10px;
}

.logo-icon{
width:35px;
height:35px;
border:2px solid var(--orange);
display:flex;
align-items:center;
justify-content:center;
font-family:'Oswald';
font-weight:700;
color:var(--orange);
font-size:16px;
}

.logo-text{
font-family:'Oswald';
font-weight:700;
color:#fff;
font-size:13px;
letter-spacing:1px;
}

.burger{
background:none;
border:1px solid rgba(255,255,255,0.2);
color:#fff;
font-size:24px;
cursor:pointer;
padding:8px;
border-radius:6px;
}

/* ===== MOBILE MENU ===== */
.mobile-menu{
position:fixed;
top:60px;
left:0;
right:0;
bottom:0;
background:rgba(0,0,0,0.95);
padding:20px;
display:none;
flex-direction:column;
gap:0;
z-index:999;
overflow-y:auto;
border:1px solid var(--orange);
}

.mobile-menu.show{
display:flex;
}

.mobile-menu a{
color:#fff;
text-decoration:none;
font-size:14px;
font-weight:600;
text-transform:uppercase;
letter-spacing:1px;
padding:15px;
border-bottom:1px solid rgba(255,255,255,0.1);
}

.mobile-menu a:hover{
color:var(--orange);
background:rgba(255,87,34,0.1);
}

.menu-admin-btn{
background:transparent;
border:2px solid var(--orange);
color:#fff;
padding:15px;
border-radius:6px;
text-align:center;
font-weight:700;
text-transform:uppercase;
cursor:pointer;
transition:.3s;
margin-top:20px;
}

.menu-admin-btn:hover{
background:var(--orange);
color:#000;
}

/* ===== MAIN CONTENT ===== */
main{
padding-top:60px;
}

section{
min-height:100vh;
display:flex;
align-items:center;
justify-content:center;
padding:40px 20px;
}

.container{
max-width:900px;
width:100%;
}

/* ===== HERO ===== */
#hero{
text-align:center;
}

.hero-tag{
display:inline-block;
color:var(--orange);
font-size:12px;
text-transform:uppercase;
letter-spacing:2px;
margin-bottom:20px;
font-weight:700;
}

.hero-title{
font-family:'Oswald';
font-size:56px;
color:#fff;
text-transform:uppercase;
letter-spacing:3px;
font-weight:700;
line-height:1.3;
margin:20px 0;
}

.hero-subtitle{
font-size:16px;
opacity:0.85;
margin:25px 0 40px;
line-height:1.6;
}

.hero-buttons{
display:flex;
gap:15px;
justify-content:center;
flex-wrap:wrap;
margin-top:30px;
}

.btn{
background:var(--orange);
color:#000;
padding:16px 30px;
border:none;
border-radius:4px;
font-weight:700;
font-size:12px;
text-transform:uppercase;
letter-spacing:1px;
cursor:pointer;
transition:.3s;
font-family:'Roboto Condensed',sans-serif;
}

.btn:hover{
background:#ff6b42;
transform:scale(1.02);
}

.btn-outline{
background:transparent;
color:#fff;
border:2px solid rgba(255,255,255,0.3);
}

.btn-outline:hover{
border-color:var(--orange);
background:rgba(255,87,34,0.1);
}

/* ===== VIDEO SECTION ===== */
#video-section{
padding:40px 20px;
display:flex;
align-items:center;
justify-content:center;
min-height:auto;
}

.video-container{
max-width:900px;
width:100%;
}

.video-box{
background:linear-gradient(135deg, #1a0f06 0%, #2a1a0f 100%);
border:2px solid var(--orange);
border-radius:8px;
overflow:hidden;
aspect-ratio:16/9;
display:flex;
align-items:center;
justify-content:center;
position:relative;
margin-bottom:30px;
}

.video-placeholder{
width:100%;
height:100%;
display:flex;
align-items:center;
justify-content:center;
font-size:80px;
opacity:0.7;
}

.video-title{
font-family:'Oswald';
font-size:24px;
color:#fff;
text-align:center;
margin:20px 0;
text-transform:uppercase;
}

.video-hint{
text-align:center;
color:rgba(255,255,255,0.5);
font-size:13px;
}

/* ===== MISSION SECTION ===== */
#mission{
text-align:left;
padding:40px 20px;
}

.mission-tag{
color:var(--orange);
font-size:12px;
text-transform:uppercase;
letter-spacing:2px;
font-weight:700;
}

.mission-title{
font-family:'Oswald';
font-size:48px;
color:#fff;
text-transform:uppercase;
letter-spacing:2px;
font-weight:700;
margin:25px 0;
line-height:1.3;
}

.mission-subtitle{
font-size:14px;
opacity:0.8;
line-height:1.8;
margin:20px 0;
}

/* ===== VOTING ===== */
#voting{
padding:40px 20px;
}

.voting-title{
font-family:'Oswald';
font-size:28px;
color:var(--orange);
text-transform:uppercase;
letter-spacing:2px;
margin-bottom:30px;
}

.voting-card{
background:transparent;
border:2px solid rgba(255,255,255,0.2);
border-radius:8px;
padding:30px 25px;
margin:20px 0;
}

.voting-label{
color:var(--orange);
font-size:11px;
text-transform:uppercase;
font-weight:700;
letter-spacing:1px;
}

.voting-question{
font-family:'Oswald';
font-size:20px;
color:#fff;
margin:15px 0;
text-transform:uppercase;
}

.voting-desc{
font-size:13px;
opacity:0.8;
margin:15px 0;
}

.vote-count{
font-family:'Oswald';
font-size:40px;
color:var(--orange);
font-weight:700;
margin:20px 0;
}

/* ===== VIDEOS SECTION ===== */
#videos{
padding:40px 20px;
}

.videos-title{
font-family:'Oswald';
font-size:28px;
color:var(--orange);
text-transform:uppercase;
letter-spacing:2px;
margin-bottom:30px;
}

.videos-grid{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
gap:20px;
margin:30px 0;
}

.video-card{
background:transparent;
border:2px solid var(--orange);
border-radius:8px;
overflow:hidden;
transition:.3s;
}

.video-card:hover{
transform:scale(1.02);
box-shadow:0 0 20px rgba(255,87,34,0.3);
}

.video-card-placeholder{
background:linear-gradient(135deg, #1a0f06 0%, #2a1a0f 100%);
height:150px;
display:flex;
align-items:center;
justify-content:center;
font-size:50px;
}

.video-info{
padding:15px;
}

.video-time{
background:rgba(0,0,0,0.5);
display:inline-block;
padding:5px 10px;
border-radius:4px;
font-size:11px;
margin-bottom:8px;
}

.video-title{
font-family:'Oswald';
font-size:14px;
color:#fff;
font-weight:700;
margin:10px 0;
text-transform:uppercase;
}

.video-status{
color:var(--orange);
font-weight:700;
font-size:10px;
text-transform:uppercase;
}

/* ===== TELEGRAM ===== */
#telegram{
padding:40px 20px;
}

.telegram-title{
font-family:'Oswald';
font-size:28px;
color:var(--orange);
text-transform:uppercase;
letter-spacing:2px;
margin-bottom:30px;
}

.tg-card{
background:transparent;
border:2px solid rgba(255,255,255,0.2);
padding:30px 25px;
border-radius:8px;
text-align:center;
margin:20px 0;
}

.tg-icon{
font-size:36px;
margin-bottom:15px;
}

.tg-text{
font-size:15px;
margin:20px 0;
line-height:1.7;
opacity:0.9;
}

.form-section{
background:transparent;
border:2px solid rgba(255,255,255,0.2);
padding:30px 25px;
border-radius:8px;
margin:20px 0;
}

.form-title{
font-family:'Oswald';
font-size:18px;
color:#fff;
text-transform:uppercase;
margin-bottom:20px;
}

.form-group{
margin-bottom:12px;
}

.form-label{
display:block;
font-weight:600;
color:var(--orange);
font-size:11px;
text-transform:uppercase;
margin-bottom:6px;
letter-spacing:1px;
}

.form-input,
.form-textarea{
width:100%;
padding:12px;
background:rgba(0,0,0,0.3);
border:1px solid rgba(255,255,255,0.1);
color:#fff;
border-radius:4px;
font-family:'Roboto Condensed',sans-serif;
font-size:13px;
transition:.3s;
}

.form-input:focus,
.form-textarea:focus{
outline:none;
border-color:var(--orange);
background:rgba(0,0,0,0.5);
}

.form-textarea{
resize:vertical;
min-height:90px;
}

/* ===== ADMIN ===== */
.admin-btn{
position:fixed;
bottom:30px;
right:30px;
width:56px;
height:56px;
background:var(--orange);
color:#000;
border:none;
border-radius:50%;
font-size:24px;
cursor:pointer;
z-index:2000;
display:flex;
align-items:center;
justify-content:center;
box-shadow:0 4px 20px rgba(255,87,34,0.4);
transition:.3s;
font-weight:700;
}

.admin-btn:hover{
transform:scale(1.1);
}

.modal{
position:fixed;
top:0;
left:0;
width:100%;
height:100%;
background:rgba(0,0,0,0.95);
display:none;
z-index:3000;
overflow-y:auto;
align-items:center;
justify-content:center;
}

.modal.show{
display:flex;
}

.modal-content{
background:var(--darker);
border:2px solid var(--orange);
padding:25px;
border-radius:8px;
width:90%;
max-width:550px;
max-height:90vh;
overflow-y:auto;
}

.modal-header{
display:flex;
justify-content:space-between;
align-items:center;
margin-bottom:25px;
border-bottom:1px solid rgba(255,255,255,0.1);
padding-bottom:15px;
}

.modal-title{
font-family:'Oswald';
font-size:20px;
color:var(--orange);
text-transform:uppercase;
}

.close-btn{
background:none;
border:none;
color:#fff;
font-size:28px;
cursor:pointer;
opacity:0.7;
transition:.3s;
}

.close-btn:hover{
opacity:1;
color:var(--orange);
}

.admin-section{
margin:15px 0;
padding:12px;
background:rgba(255,87,34,0.05);
border-left:3px solid var(--orange);
border-radius:4px;
}

.admin-section h3{
font-family:'Oswald';
color:var(--orange);
margin-bottom:12px;
font-size:12px;
text-transform:uppercase;
}

.admin-input{
width:100%;
padding:9px;
margin:6px 0;
background:var(--dark);
border:1px solid rgba(255,255,255,0.1);
color:#fff;
border-radius:4px;
font-size:12px;
transition:.3s;
}

.admin-input:focus{
outline:none;
border-color:var(--orange);
}

.admin-actions{
display:flex;
gap:8px;
margin-top:20px;
}

.admin-actions button{
flex:1;
padding:10px;
border:none;
border-radius:4px;
font-weight:600;
cursor:pointer;
transition:.3s;
text-transform:uppercase;
font-size:11px;
}

.btn-save{
background:var(--orange);
color:#000;
}

.btn-save:hover{
background:#ff6b42;
}

.btn-reset{
background:rgba(255,255,255,0.1);
color:#fff;
}

.btn-reset:hover{
background:rgba(255,87,34,0.2);
}

.btn-exit{
background:transparent;
border:1px solid rgba(255,255,255,0.2);
color:#fff;
margin-bottom:15px;
width:100%;
}

.btn-exit:hover{
border-color:var(--orange);
background:rgba(255,87,34,0.1);
}

/* ===== RESPONSIVE ===== */
@media(max-width:768px){
.hero-title{font-size:32px}
.mission-title{font-size:28px}
.videos-grid{grid-template-columns:1fr}
.hero-buttons{flex-direction:column}
.btn{width:100%}
}

@media(max-width:480px){
header{padding:10px 15px}
.logo-icon{width:32px;height:32px;font-size:14px}
.hero-title{font-size:24px;letter-spacing:2px}
.mission-title{font-size:20px}
section{padding:30px 12px}
.vote-count{font-size:32px}
.admin-btn{width:48px;height:48px;font-size:20px}
}
</style>
</head>

<body>

<!-- HEADER -->
<header>
<div class="logo-box">
<div class="logo-icon">ODF</div>
<div class="logo-text">ONE DAY OF FIGHTER</div>
</div>
<button class="burger" onclick="toggleMenu()">☰</button>
</header>

<!-- MOBILE MENU -->
<div class="mobile-menu" id="mobileMenu">
<a href="#hero" onclick="closeMenu()">ГЛАВНАЯ</a>
<a href="#mission" onclick="closeMenu()">О ПРОЕКТЕ</a>
<a href="#voting" onclick="closeMenu()">ГОЛОСОВАНИЕ</a>
<a href="#videos" onclick="closeMenu()">ВЫПУСКИ</a>
<a href="#telegram" onclick="closeMenu()">СТАТЬ ЧАСТЬЮ</a>
<button class="menu-admin-btn" onclick="openAdmin();closeMenu()">🔒 ВОЙТИ В АДМИН-ПАНЕЛЬ</button>
</div>

<main>

<!-- HERO -->
<section id="hero">
<div class="container">
<div style="text-align:center">
<span class="hero-tag">🔥 TELEGRAM-FIRST MMA CHALLENGE</span>
<h1 class="hero-title" id="heroTitle">ONE DAY OF FIGHTER — НАЧИНАЕМ!</h1>
<p class="hero-subtitle" id="heroSubtitle">Это не просто проект. Это вызов самому себе.</p>

<div class="hero-buttons">
<button class="btn" onclick="window.open('https://t.me/onedayoffighter','_blank')">ПОДПИСАТЬСЯ НА КАНАЛ →</button>
<button class="btn btn-outline" onclick="document.getElementById('videos').scrollIntoView({behavior:'smooth'})">СМОТРЕТЬ ВЫПУСКИ →</button>
</div>
</div>
</div>
</section>

<!-- VIDEO PREVIEW -->
<section id="video-section">
<div class="video-container">
<div class="video-box">
<div class="video-placeholder">▶</div>
</div>
<h2 class="video-title" id="videoTitle">Видео-превью</h2>
<p class="video-hint">Замените ссылку в админ-панели</p>
</div>
</section>

<!-- MISSION -->
<section id="mission">
<div class="container">
<span class="mission-tag">МИССИЯ</span>
<h1 class="mission-title" id="missionTitle">ОДИН ДЕНЬ ПО РЕЖИМУ ПРОФЕССИОНАЛЬНОГО БОЙЦА</h1>
<p class="mission-subtitle" id="missionDesc">Мы проживаем день как профессиональный боец ММА: утренний вес, функциональная работа, техника, спарринги, восстановление и честная камера без постановки. Зрители Telegram-канала выбирают, чей режим станет следующим испытанием.</p>
</div>
</section>

<!-- VOTING -->
<section id="voting">
<div class="container">
<h2 class="voting-title">ГОЛОСОВАНИЕ НЕДЕЛИ</h2>

<div class="voting-card">
<span class="voting-label">📊 ГОЛОСОВАНИЕ НЕДЕЛИ</span>
<h3 class="voting-question" id="votingQuestion">Чей режим повторяем первым?</h3>
<p class="voting-desc" id="votingDesc">Выбор недели решает Telegram-канал.</p>
<div class="vote-count" id="voteCount">487</div>
<button class="btn" onclick="window.open('https://t.me/onedayoffighter','_blank')">ПРОГОЛОСОВАТЬ В КАНАЛЕ</button>
</div>
</div>
</section>

<!-- VIDEOS -->
<section id="videos">
<div class="container">
<h2 class="videos-title">ВИДЕО ВЫПУСКИ</h2>

<div class="videos-grid" id="videosGrid">
<!-- Видео загружаются -->
</div>

<div style="text-align:center;margin-top:30px">
<button class="btn" onclick="alert('Все выпуски')">ВСЕ ВЫПУСКИ →</button>
</div>
</div>
</section>

<!-- TELEGRAM -->
<section id="telegram">
<div class="container">
<h2 class="telegram-title">ПРИСОЕДИНИСЬ В TELEGRAM</h2>

<div class="tg-card">
<div class="tg-icon">🔔</div>
<p class="tg-text" id="telegramText">Подписывайтесь на канал, включайте уведомления и решайте, чей тренировочный день станет новым выпуском.</p>
<button class="btn" onclick="window.open('https://t.me/onedayoffighter','_blank')">ПОДПИСАТЬСЯ НА @ONEDAYOFFIGHTER</button>
</div>

<div class="form-section">
<h3 class="form-title">Хотите предложить идею?</h3>
<form id="contactForm" onsubmit="submitForm(event)">
<div class="form-group">
<label class="form-label">Ваше имя</label>
<input type="text" class="form-input" id="formName" placeholder="Введите ваше имя" required>
</div>

<div class="form-group">
<label class="form-label">Telegram или Email</label>
<input type="text" class="form-input" id="formContact" placeholder="@username или email" required>
</div>

<div class="form-group">
<label class="form-label">Предложите бойца или идею выпуска</label>
<textarea class="form-textarea" id="formIdea" placeholder="Ваша идея..." required></textarea>
</div>

<button type="submit" class="btn" style="width:100%">ОТПРАВИТЬ ПРЕДЛОЖЕНИЕ</button>
</form>
</div>
</div>
</section>

</main>

<!-- ADMIN BUTTON -->
<button class="admin-btn" onclick="openAdmin()">⚙️</button>

<!-- ADMIN MODAL -->
<div id="adminModal" class="modal">
<div class="modal-content">
<div class="modal-header">
<div class="modal-title">Admin Panel</div>
<button class="close-btn" onclick="closeAdmin()">&times;</button>
</div>

<div id="loginSection">
<div class="form-group">
<label class="form-label">Пароль администратора</label>
<input type="password" class="form-input" id="adminPass" placeholder="Введите пароль" onkeypress="if(event.key==='Enter') loginAdmin()">
</div>
<button class="btn" style="width:100%;margin-top:10px" onclick="loginAdmin()">Войти</button>
</div>

<div id="adminPanel" style="display:none">
<button class="btn btn-exit" onclick="closeAdmin()">← Выйти</button>

<div class="admin-section">
<h3>ГЕРОЯ СЕКЦИЯ</h3>
<label class="form-label">Заголовок</label>
<input class="admin-input" type="text" id="editHeroTitle">

<label class="form-label">Подзаголовок</label>
<input class="admin-input" type="text" id="editHeroSubtitle">
</div>

<div class="admin-section">
<h3>МИССИЯ</h3>
<label class="form-label">Заголовок</label>
<input class="admin-input" type="text" id="editMissionTitle">

<label class="form-label">Описание</label>
<textarea class="admin-input" id="editMissionDesc" style="min-height:80px"></textarea>
</div>

<div class="admin-section">
<h3>ВИДЕО</h3>
<label class="form-label">Название видео</label>
<input class="admin-input" type="text" id="editVideoTitle">
</div>

<div class="admin-section">
<h3>ГОЛОСОВАНИЕ</h3>
<label class="form-label">Вопрос</label>
<input class="admin-input" type="text" id="editVotingQuestion">

<label class="form-label">Описание</label>
<input class="admin-input" type="text" id="editVotingDesc">

<label class="form-label">Количество голосов</label>
<input class="admin-input" type="number" id="editVoteCount">
</div>

<div class="admin-section">
<h3>ВИДЕО 1</h3>
<label class="form-label">Название</label>
<input class="admin-input" type="text" id="editVideo1Title">

<label class="form-label">Время</label>
<input class="admin-input" type="text" id="editVideo1Time">

<label class="form-label">Статус</label>
<input class="admin-input" type="text" id="editVideo1Status">
</div>

<div class="admin-section">
<h3>ВИДЕО 2</h3>
<label class="form-label">Название</label>
<input class="admin-input" type="text" id="editVideo2Title">

<label class="form-label">Время</label>
<input class="admin-input" type="text" id="editVideo2Time">

<label class="form-label">Статус</label>
<input class="admin-input" type="text" id="editVideo2Status">
</div>

<div class="admin-section">
<h3>TELEGRAM</h3>
<label class="form-label">Текст в секции</label>
<textarea class="admin-input" id="editTelegramText" style="min-height:80px"></textarea>

<label class="form-label">Контакт для связи</label>
<input class="admin-input" type="text" id="editTelegramContact">
</div>

<div class="admin-actions">
<button class="admin-actions button btn-save" onclick="saveAdmin()">💾 СОХРАНИТЬ</button>
<button class="admin-actions button btn-reset" onclick="resetAdmin()">↻ СБРОСИТЬ</button>
</div>
</div>
</div>
</div>

<script>
const defaultData = {
heroTitle: 'ONE DAY OF FIGHTER — НАЧИНАЕМ!',
heroSubtitle: 'Это не просто проект. Это вызов самому себе.',
missionTitle: 'ОДИН ДЕНЬ ПО РЕЖИМУ ПРОФЕССИОНАЛЬНОГО БОЙЦА',
missionDesc: 'Мы проживаем день как профессиональный боец ММА: утренний вес, функциональная работа, техника, спарринги, восстановление и честная камера без постановки. Зрители Telegram-канала выбирают, чей режим станет следующим испытанием.',
videoTitle: 'Видео-превью',
votingQuestion: 'Чей режим повторяем первым?',
votingDesc: 'Выбор недели решает Telegram-канал.',
voteCount: '487',
video1Title: 'Пилот: день бойца без дублей',
video1Time: '15 д. 11 ч.',
video1Status: 'СКОРО',
video2Title: 'Октагон начинается утром',
video2Time: '29 д. 11 ч.',
video2Status: 'СКОРО',
telegramText: 'Подписывайтесь на канал, включайте уведомления и решайте, чей тренировочный день станет новым выпуском.',
telegramContact: '@zloypankrationists'
};

function loadData(){
const saved = localStorage.getItem('odfData');
return saved ? JSON.parse(saved) : defaultData;
}

function saveData(data){
localStorage.setItem('odfData', JSON.stringify(data));
}

function renderPage(){
const data = loadData();
document.getElementById('heroTitle').textContent = data.heroTitle;
document.getElementById('heroSubtitle').textContent = data.heroSubtitle;
document.getElementById('missionTitle').textContent = data.missionTitle;
document.getElementById('missionDesc').textContent = data.missionDesc;
document.getElementById('videoTitle').textContent = data.videoTitle;
document.getElementById('votingQuestion').textContent = data.votingQuestion;
document.getElementById('votingDesc').textContent = data.votingDesc;
document.getElementById('voteCount').textContent = data.voteCount;
document.getElementById('telegramText').textContent = data.telegramText;
renderVideos(data);
}

function renderVideos(data){
const grid = document.getElementById('videosGrid');
grid.innerHTML = '';
const videos = [
{title: data.video1Title, time: data.video1Time, status: data.video1Status},
{title: data.video2Title, time: data.video2Time, status: data.video2Status}
];
videos.forEach(v => {
const html = `
<div class="video-card">
<div class="video-card-placeholder">▶</div>
<div class="video-info">
<div class="video-time">⏱ ${v.time}</div>
<div class="video-title">${v.title}</div>
<div class="video-status">${v.status}</div>
</div>
</div>
`;
grid.innerHTML += html;
});
}

function toggleMenu(){
document.getElementById('mobileMenu').classList.toggle('show');
}

function closeMenu(){
document.getElementById('mobileMenu').classList.remove('show');
}

function openAdmin(){
document.getElementById('adminModal').classList.add('show');
}

function closeAdmin(){
document.getElementById('adminModal').classList.remove('show');
document.getElementById('loginSection').style.display = 'block';
document.getElementById('adminPanel').style.display = 'none';
document.getElementById('adminPass').value = '';
}

function loginAdmin(){
const pass = document.getElementById('adminPass').value;
if(pass === 'Dmitri1987'){
document.getElementById('loginSection').style.display = 'none';
document.getElementById('adminPanel').style.display = 'block';
loadAdminForm();
}else{
alert('❌ Неверный пароль!');
}
}

function loadAdminForm(){
const data = loadData();
document.getElementById('editHeroTitle').value = data.heroTitle;
document.getElementById('editHeroSubtitle').value = data.heroSubtitle;
document.getElementById('editMissionTitle').value = data.missionTitle;
document.getElementById('editMissionDesc').value = data.missionDesc;
document.getElementById('editVideoTitle').value = data.videoTitle;
document.getElementById('editVotingQuestion').value = data.votingQuestion;
document.getElementById('editVotingDesc').value = data.votingDesc;
document.getElementById('editVoteCount').value = data.voteCount;
document.getElementById('editVideo1Title').value = data.video1Title;
document.getElementById('editVideo1Time').value = data.video1Time;
document.getElementById('editVideo1Status').value = data.video1Status;
document.getElementById('editVideo2Title').value = data.video2Title;
document.getElementById('editVideo2Time').value = data.video2Time;
document.getElementById('editVideo2Status').value = data.video2Status;
document.getElementById('editTelegramText').value = data.telegramText;
document.getElementById('editTelegramContact').value = data.telegramContact;
}

function saveAdmin(){
const data = {
heroTitle: document.getElementById('editHeroTitle').value,
heroSubtitle: document.getElementById('editHeroSubtitle').value,
missionTitle: document.getElementById('editMissionTitle').value,
missionDesc: document.getElementById('editMissionDesc').value,
videoTitle: document.getElementById('editVideoTitle').value,
votingQuestion: document.getElementById('editVotingQuestion').value,
votingDesc: document.getElementById('editVotingDesc').value,
voteCount: document.getElementById('editVoteCount').value,
video1Title: document.getElementById('editVideo1Title').value,
video1Time: document.getElementById('editVideo1Time').value,
video1Status: document.getElementById('editVideo1Status').value,
video2Title: document.getElementById('editVideo2Title').value,
video2Time: document.getElementById('editVideo2Time').value,
video2Status: document.getElementById('editVideo2Status').value,
telegramText: document.getElementById('editTelegramText').value,
telegramContact: document.getElementById('editTelegramContact').value
};
saveData(data);
renderPage();
alert('✅ Сохранено!');
closeAdmin();
}

function resetAdmin(){
if(confirm('Сбросить все значения?')){
localStorage.removeItem('odfData');
renderPage();
alert('✅ Сброшено!');
loadAdminForm();
}
}

// ===== ИЗМЕНЕННАЯ ФУНКЦИЯ ОТПРАВКИ ФОРМЫ =====
function submitForm(e) {
  e.preventDefault();
  const name = document.getElementById('formName').value;
  const contact = document.getElementById('formContact').value;
  const idea = document.getElementById('formIdea').value;
  const data = loadData();
  const tg = data.telegramContact.replace('@', '').trim();

  if (!tg) {
    alert('⚠️ Контакт для связи не задан в админ-панели.');
    return;
  }

  const message = `здравствуйте я из сайта, уделиите время пожалуйста

Имя: ${name}
Контакт: ${contact}
Идея: ${idea}`;

  window.open(`https://t.me/${tg}?text=${encodeURIComponent(message)}`, '_blank');
  alert('✅ Предложение отправлено в Telegram!');
  document.getElementById('contactForm').reset();
}
// ===========================================

renderPage();
</script>

</body>
</html>
